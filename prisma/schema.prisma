generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum MetricType {
  PRICE_DIRECTION
  PRICE_TARGET
  PERCENTAGE_MOVE
}

enum Side {
  YES
  NO
}

enum MarketStatus {
  OPEN      // accepting orders
  CLOSED    // earnings window; no new orders
  RESOLVED
  VOIDED
}

enum OrderStatus {
  OPEN
  FILLED
  PARTIALLY_FILLED
  CANCELLED
}

enum OrderAction {
  BUY
  SELL
}

enum OrderType {
  LIMIT
  MARKET
}

enum ReleaseTime {
  PRE_MARKET   // bmo — bets close at 9:00 AM on reportDate
  POST_MARKET  // amc — bets close at 4:30 PM on reportDate
}

enum ChallengeStatus {
  OPEN
  LOCKED
  RESOLVED
  VOIDED
}

enum PayoutType {
  WINNER_TAKES_ALL
  TOP_THREE_SPLIT
}

enum LeagueJoinMode {
  INVITE
  OPEN
}

enum FeedEventType {
  BET_PLACED
  CHALLENGE_WON
  STREAK
  CHALLENGE_CREATED
}

enum ChallengeType {
  ADMIN
  USER
}

// ─────────────────────────────────────────────────────────────────────────────
// Company
// ─────────────────────────────────────────────────────────────────────────────

model Company {
  id                   String    @id @default(cuid())
  ticker               String    @unique
  name                 String
  logoUrl              String?
  sector               String?
  lastEarningsSyncAt   DateTime?
  lastPriceSyncAt      DateTime?
  createdAt            DateTime  @default(now())

  earningsEvents   EarningsEvent[]
  markets          Market[]
  stockPrices      StockPriceCache[]
  companyWatchlist CompanyWatchlist[]
}

// ─────────────────────────────────────────────────────────────────────────────
// EarningsEvent
// One event per quarter per company; multiple contracts hang off it.
// ─────────────────────────────────────────────────────────────────────────────

model EarningsEvent {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  quarter     String    // e.g. "Q1-2026"
  reportDate  DateTime  // expected release datetime (UTC)
  isConfirmed Boolean      @default(false)
  releaseTime ReleaseTime  @default(POST_MARKET)
  createdAt   DateTime     @default(now())

  markets Market[]

  @@unique([companyId, quarter])
  @@index([reportDate])
}

// ─────────────────────────────────────────────────────────────────────────────
// StockPriceCache
// Daily OHLCV data pulled from FMP API; read by the UI for stock charts.
// ─────────────────────────────────────────────────────────────────────────────

model StockPriceCache {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  date      DateTime @db.Date
  open      Decimal  @db.Decimal(12, 4)
  high      Decimal  @db.Decimal(12, 4)
  low       Decimal  @db.Decimal(12, 4)
  close     Decimal  @db.Decimal(12, 4)
  volume    BigInt

  @@unique([companyId, date])
  @@index([companyId, date])
}

// ─────────────────────────────────────────────────────────────────────────────
// Market
// One binary contract: "Will AAPL gross margin exceed 47% in Q1-2026?"
// ─────────────────────────────────────────────────────────────────────────────

model Market {
  id              String       @id @default(cuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id])
  earningsEventId String?
  earningsEvent   EarningsEvent? @relation(fields: [earningsEventId], references: [id])

  // Contract definition
  question        String
  metricType      MetricType
  threshold       Decimal      @db.Decimal(18, 4)
  thresholdLabel  String
  resolutionCriteria String?  @db.Text
  status          MarketStatus @default(OPEN)
  betDate         DateTime?    @db.Date

  // Analyst context (denormalised for fast reads)
  consensusEstimate String?
  priorPeriod       String?
  analystRangeLow   Decimal?   @db.Decimal(18, 4)
  analystRangeHigh  Decimal?   @db.Decimal(18, 4)

  // Current price state — stored as integer cents (1–99)
  yesPriceLatest  Int          @default(50)
  noPriceLatest   Int          @default(50)
  volume24h       BigInt       @default(0)
  totalVolume     BigInt       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders              Order[]
  positions           Position[]
  trades              Trade[]
  probabilitySnaps    ProbabilitySnapshot[]
  resolution          Resolution?
  watchlist           Watchlist[]
  challengeMarkets ChallengeMarket[]
  challengePicks   ChallengePick[]   @relation("ChallengePickMarket")

  @@index([status])
  @@index([companyId, status])
  @@index([betDate, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// ProbabilitySnapshot
// Append-only time-series for sparklines and probability charts.
// ─────────────────────────────────────────────────────────────────────────────

model ProbabilitySnapshot {
  id          String   @id @default(cuid())
  marketId    String
  market      Market   @relation(fields: [marketId], references: [id])
  probability Int      // 0–100
  recordedAt  DateTime @default(now())

  @@index([marketId, recordedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Order
// ─────────────────────────────────────────────────────────────────────────────

model Order {
  id           String      @id @default(cuid())
  marketId     String
  market       Market      @relation(fields: [marketId], references: [id])
  userId       String
  user         User        @relation(fields: [userId], references: [id])

  side         Side
  action       OrderAction @default(BUY)
  orderType    OrderType   @default(LIMIT)
  price        Int?        // cents (1–99); null for market orders
  shares       Int
  filledShares Int         @default(0)
  status       OrderStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyTrades  Trade[] @relation("BuyOrder")
  sellTrades Trade[] @relation("SellOrder")

  @@index([marketId, side, price, status])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Trade  (matched pair of orders)
// ─────────────────────────────────────────────────────────────────────────────

model Trade {
  id          String   @id @default(cuid())
  marketId    String
  market      Market   @relation(fields: [marketId], references: [id])
  buyOrderId  String
  buyOrder    Order    @relation("BuyOrder",  fields: [buyOrderId],  references: [id])
  sellOrderId String?
  sellOrder   Order?   @relation("SellOrder", fields: [sellOrderId], references: [id])

  side        Side
  price       Int      // cents
  shares      Int
  executedAt  DateTime @default(now())

  @@index([marketId, executedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Position  (aggregate per user × market × side)
// ─────────────────────────────────────────────────────────────────────────────

model Position {
  id             String   @id @default(cuid())
  marketId       String
  market         Market   @relation(fields: [marketId], references: [id])
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  side           Side
  shares         Int
  avgCostCents   Int      // weighted average entry price (cents)
  currentPrice   Int      // latest market price for this side (cents)
  unrealizedPL   Int      @default(0)  // cents; updated on each fill
  realizedPL     Int?             // cents; null while open, set on resolution

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([marketId, userId, side])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Resolution
// ─────────────────────────────────────────────────────────────────────────────

model Resolution {
  id               String    @id @default(cuid())
  marketId         String    @unique
  market           Market    @relation(fields: [marketId], references: [id])

  actualValue      Decimal   @db.Decimal(18, 4)
  actualLabel      String    // e.g. "47.3%"
  winningSide      Side
  sourceFiling     String    // SEC EDGAR URL

  resolvedAt       DateTime  @default(now())
  payoutsIssuedAt  DateTime?
}

// ─────────────────────────────────────────────────────────────────────────────
// CompanyWatchlist
// User-bookmarked companies shown on the portfolio watchlist tab.
// ─────────────────────────────────────────────────────────────────────────────

model CompanyWatchlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, companyId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Watchlist
// User-bookmarked individual markets shown on the portfolio watchlist tab.
// ─────────────────────────────────────────────────────────────────────────────

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, marketId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Challenge
// ─────────────────────────────────────────────────────────────────────────────

model Challenge {
  id            String          @id @default(cuid())
  title         String
  type          ChallengeType   @default(USER)
  creatorId     String?
  creator       User?           @relation("CreatedChallenges", fields: [creatorId], references: [id])
  status        ChallengeStatus @default(OPEN)
  entryFeeCents Int             @default(0)
  payoutType    PayoutType      @default(WINNER_TAKES_ALL)
  betDate       DateTime        @db.Date
  inviteSlug    String          @unique
  createdAt     DateTime        @default(now())
  resolvedAt    DateTime?

  markets ChallengeMarket[]
  entries ChallengeEntry[]

  @@index([status, betDate])
  @@index([creatorId])
}

model ChallengeMarket {
  id          String    @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  marketId    String
  market      Market    @relation(fields: [marketId], references: [id])

  @@unique([challengeId, marketId])
  @@index([marketId])
}

model ChallengeEntry {
  id          String    @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  userId      String
  user        User      @relation("ChallengeEntries", fields: [userId], references: [id])
  score       Int       @default(0)
  payout      Int       @default(0)
  rank        Int?
  createdAt   DateTime  @default(now())

  picks ChallengePick[]

  @@unique([challengeId, userId])
  @@index([userId])
}

model ChallengePick {
  id       String         @id @default(cuid())
  entryId  String
  entry    ChallengeEntry @relation(fields: [entryId], references: [id])
  marketId String
  market   Market         @relation("ChallengePickMarket", fields: [marketId], references: [id])
  side     Side
  correct  Boolean?

  @@unique([entryId, marketId])
  @@index([marketId])
}

// ─────────────────────────────────────────────────────────────────────────────
// League (schema only — logic implemented in Plan 2)
// ─────────────────────────────────────────────────────────────────────────────

model League {
  id         String         @id @default(cuid())
  name       String
  creatorId  String
  creator    User           @relation("CreatedLeagues", fields: [creatorId], references: [id])
  joinMode   LeagueJoinMode @default(INVITE)
  inviteSlug String         @unique
  createdAt  DateTime       @default(now())

  members LeagueMember[]
}

model LeagueMember {
  id       String   @id @default(cuid())
  leagueId String
  league   League   @relation(fields: [leagueId], references: [id])
  userId   String
  user     User     @relation("LeagueMemberships", fields: [userId], references: [id])
  isOwner  Boolean  @default(false)
  joinedAt DateTime @default(now())

  @@unique([leagueId, userId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FeedEvent (schema only — logic implemented in Plan 2)
// ─────────────────────────────────────────────────────────────────────────────

model FeedEvent {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation("FeedEvents", fields: [userId], references: [id])
  eventType FeedEventType
  refId     String?
  metadata  Json?
  createdAt DateTime      @default(now())

  @@index([userId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// User
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  emailVerified    DateTime?
  password         String?
  displayName      String?
  avatarUrl        String?
  cashBalanceCents BigInt     @default(0)
  lastTopUpAt      DateTime?
  username         String?    @unique
  lastBonusAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  accounts         Account[]
  orders           Order[]
  positions        Position[]
  companyWatchlist CompanyWatchlist[]
  watchlist        Watchlist[]
  challengesCreated Challenge[]    @relation("CreatedChallenges")
  challengeEntries  ChallengeEntry[] @relation("ChallengeEntries")
  leaguesCreated    League[]       @relation("CreatedLeagues")
  leagueMembers     LeagueMember[] @relation("LeagueMemberships")
  feedEvents        FeedEvent[]    @relation("FeedEvents")
}

// ─────────────────────────────────────────────────────────────────────────────
// NextAuth adapter models
// ─────────────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────────────────────
// Email verification (custom — separate from NextAuth's VerificationToken)
// ─────────────────────────────────────────────────────────────────────────────

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// Setting
// Key-value store for admin-configurable settings.
// ─────────────────────────────────────────────────────────────────────────────

model Setting {
  key   String @id
  value String @db.Text
}
