generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum MetricType {
  EPS
  GROSS_MARGIN
  REVENUE_GROWTH
  OPERATING_MARGIN
  FREE_CASH_FLOW
  ARPU
  SUBSCRIBERS
}

enum Side {
  YES
  NO
}

enum MarketStatus {
  OPEN      // accepting orders
  CLOSED    // earnings window; no new orders
  RESOLVED
  VOIDED
}

enum OrderStatus {
  OPEN
  FILLED
  PARTIALLY_FILLED
  CANCELLED
}

enum ReleaseTime {
  PRE_MARKET   // bmo — bets close at 9:00 AM on reportDate
  POST_MARKET  // amc — bets close at 4:30 PM on reportDate
}

// ─────────────────────────────────────────────────────────────────────────────
// Company
// ─────────────────────────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(cuid())
  ticker    String   @unique
  name      String
  logoUrl   String?
  sector    String?
  createdAt DateTime @default(now())

  earningsEvents   EarningsEvent[]
  markets          Market[]
  stockPrices      StockPriceCache[]
  companyWatchlist CompanyWatchlist[]
}

// ─────────────────────────────────────────────────────────────────────────────
// EarningsEvent
// One event per quarter per company; multiple contracts hang off it.
// ─────────────────────────────────────────────────────────────────────────────

model EarningsEvent {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  quarter     String    // e.g. "Q1-2026"
  reportDate  DateTime  // expected release datetime (UTC)
  isConfirmed Boolean      @default(false)
  releaseTime ReleaseTime  @default(POST_MARKET)
  createdAt   DateTime     @default(now())

  markets Market[]

  @@unique([companyId, quarter])
  @@index([reportDate])
}

// ─────────────────────────────────────────────────────────────────────────────
// StockPriceCache
// Daily OHLCV data pulled from FMP API; read by the UI for stock charts.
// ─────────────────────────────────────────────────────────────────────────────

model StockPriceCache {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  date      DateTime @db.Date
  open      Decimal  @db.Decimal(12, 4)
  high      Decimal  @db.Decimal(12, 4)
  low       Decimal  @db.Decimal(12, 4)
  close     Decimal  @db.Decimal(12, 4)
  volume    BigInt

  @@unique([companyId, date])
  @@index([companyId, date])
}

// ─────────────────────────────────────────────────────────────────────────────
// Market
// One binary contract: "Will AAPL gross margin exceed 47% in Q1-2026?"
// ─────────────────────────────────────────────────────────────────────────────

model Market {
  id              String       @id @default(cuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id])
  earningsEventId String
  earningsEvent   EarningsEvent @relation(fields: [earningsEventId], references: [id])

  // Contract definition
  question        String       // "Will AAPL gross margin exceed 47%?"
  metricType      MetricType
  threshold       Decimal      @db.Decimal(18, 4)
  thresholdLabel  String       // "> 47%"
  status          MarketStatus @default(OPEN)

  // Analyst context (denormalised for fast reads)
  consensusEstimate String?
  priorPeriod       String?
  analystRangeLow   Decimal?   @db.Decimal(18, 4)
  analystRangeHigh  Decimal?   @db.Decimal(18, 4)

  // Current price state — stored as integer cents (1–99)
  yesPriceLatest  Int          @default(50)
  noPriceLatest   Int          @default(50)
  volume24h       BigInt       @default(0)  // cents
  totalVolume     BigInt       @default(0)  // cents

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders              Order[]
  positions           Position[]
  trades              Trade[]
  probabilitySnaps    ProbabilitySnapshot[]
  resolution          Resolution?
  watchlist           Watchlist[]

  @@index([status])
  @@index([companyId, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// ProbabilitySnapshot
// Append-only time-series for sparklines and probability charts.
// ─────────────────────────────────────────────────────────────────────────────

model ProbabilitySnapshot {
  id          String   @id @default(cuid())
  marketId    String
  market      Market   @relation(fields: [marketId], references: [id])
  probability Int      // 0–100
  recordedAt  DateTime @default(now())

  @@index([marketId, recordedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Order
// ─────────────────────────────────────────────────────────────────────────────

model Order {
  id           String      @id @default(cuid())
  marketId     String
  market       Market      @relation(fields: [marketId], references: [id])
  userId       String
  user         User        @relation(fields: [userId], references: [id])

  side         Side
  price        Int         // cents (1–99)
  shares       Int
  filledShares Int         @default(0)
  status       OrderStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyTrades  Trade[] @relation("BuyOrder")
  sellTrades Trade[] @relation("SellOrder")

  @@index([marketId, side, price, status])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Trade  (matched pair of orders)
// ─────────────────────────────────────────────────────────────────────────────

model Trade {
  id          String   @id @default(cuid())
  marketId    String
  market      Market   @relation(fields: [marketId], references: [id])
  buyOrderId  String
  buyOrder    Order    @relation("BuyOrder",  fields: [buyOrderId],  references: [id])
  sellOrderId String?
  sellOrder   Order?   @relation("SellOrder", fields: [sellOrderId], references: [id])

  side        Side
  price       Int      // cents
  shares      Int
  executedAt  DateTime @default(now())

  @@index([marketId, executedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Position  (aggregate per user × market × side)
// ─────────────────────────────────────────────────────────────────────────────

model Position {
  id             String   @id @default(cuid())
  marketId       String
  market         Market   @relation(fields: [marketId], references: [id])
  userId         String
  user           User     @relation(fields: [userId], references: [id])

  side           Side
  shares         Int
  avgCostCents   Int      // weighted average entry price (cents)
  currentPrice   Int      // latest market price for this side (cents)
  unrealizedPL   Int      @default(0)  // cents; updated on each fill
  realizedPL     Int?             // cents; null while open, set on resolution

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([marketId, userId, side])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Resolution
// ─────────────────────────────────────────────────────────────────────────────

model Resolution {
  id               String    @id @default(cuid())
  marketId         String    @unique
  market           Market    @relation(fields: [marketId], references: [id])

  actualValue      Decimal   @db.Decimal(18, 4)
  actualLabel      String    // e.g. "47.3%"
  winningSide      Side
  sourceFiling     String    // SEC EDGAR URL

  resolvedAt       DateTime  @default(now())
  payoutsIssuedAt  DateTime?
}

// ─────────────────────────────────────────────────────────────────────────────
// CompanyWatchlist
// User-bookmarked companies shown on the portfolio watchlist tab.
// ─────────────────────────────────────────────────────────────────────────────

model CompanyWatchlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, companyId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Watchlist
// User-bookmarked individual markets shown on the portfolio watchlist tab.
// ─────────────────────────────────────────────────────────────────────────────

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, marketId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// User
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  emailVerified    DateTime?
  password         String?
  displayName      String?
  avatarUrl        String?
  cashBalanceCents BigInt     @default(0)
  lastTopUpAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  accounts         Account[]
  orders           Order[]
  positions        Position[]
  companyWatchlist CompanyWatchlist[]
  watchlist        Watchlist[]
}

// ─────────────────────────────────────────────────────────────────────────────
// NextAuth adapter models
// ─────────────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────────────────────
// Email verification (custom — separate from NextAuth's VerificationToken)
// ─────────────────────────────────────────────────────────────────────────────

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}
